[
  {
    "_comment": "CONTENT: Daily content drafting run",
    "id": "GENERATE_YOUR_OWN_UUID",
    "agentId": "{{CONTENT_AGENT_ID}}",
    "name": "daily-content-run",
    "enabled": false,
    "schedule": {
      "kind": "cron",
      "expr": "0 5 * * 1-5",
      "tz": "{{YOUR_TIMEZONE}}"
    },
    "sessionTarget": "isolated",
    "wakeMode": "next-heartbeat",
    "payload": {
      "kind": "agentTurn",
      "text": "Good morning. Run your daily content session: check active drafts, produce today's content, post to Slack for review.",
      "model": "{{YOUR_PRIMARY_MODEL}}",
      "timeoutSeconds": 600
    }
  },
  {
