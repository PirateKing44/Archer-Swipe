# ============================================================
# STERLING AI STARTER KIT — Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys.
# Only fill in the services you plan to use.
# ============================================================

# --- LLM PROVIDERS (pick at least one) ---

# Anthropic (recommended for orchestration)
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini (recommended for vision/image tasks)
# Get your key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# MiniMax (recommended as primary workhorse — fast + cheap)
# Get your key: https://platform.minimaxi.com/
MINIMAX_API_KEY=

# OpenRouter (optional — multi-model routing)
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- COMMUNICATION CHANNELS ---

# Slack Bot (required for agent channels)
# Create app: https://api.slack.com/apps → Socket Mode
SLACK_BOT_TOKEN=xoxb-
SLACK_APP_TOKEN=xapp-1-

# Telegram Bot (optional — mobile quick-drop)
# Create bot: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# --- GTM / OUTREACH PIPELINE ---

# LeadMagic (email enrichment + verification)
# Get your key: https://leadmagic.io/
LEADMAGIC_API_KEY=

# Apollo.io (fallback email finder — free tier: 50 credits/mo)
# Get your key: https://app.apollo.io/#/settings/integrations/api-keys
APOLLO_API_KEY=

# RapidAPI (LinkedIn mining via Fresh LinkedIn Profile Data)
# Get your key: https://rapidapi.com/freshdata-freshdata-default/api/fresh-linkedin-profile-data
RAPIDAPI_KEY=

# Instantly.ai (email campaign sending)
# Get your key: https://app.instantly.ai/settings/integrations
INSTANTLY_API_KEY=

# --- LINKEDIN (browser automation) ---

# LinkedIn session cookies (for Apify/browser CDP scraping)
# Extract from browser DevTools → Application → Cookies → linkedin.com
LINKEDIN_LI_AT=
LINKEDIN_JSESSIONID=

# --- CREATIVE / VIDEO ---

# Airtable (creative review hub for video/image assets)
# Get your key: https://airtable.com/create/tokens
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# --- OPTIONAL ---

# Perplexity (AI-powered research for pre-call briefs)
# Get your key: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# SocialPilot (social media scheduling)
SOCIALPILOT_API_KEY=
